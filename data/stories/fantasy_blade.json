              "choices": []
            },
            "n_09": {
              "text": "تهربان للغابات، يعيش منبوذاً خائفاً وأنت تستهلك روحه ببطء حتى الجنون.",
              "is_ending": true,
              "choices": []
            },
            "n_10": {
              "text": "القائد يقتل الملك. يتربع على العرش وأنت جانبه، الحاكم الفعلي للمملكة.",
