            "n_08": {
              "text": "تحطم الجبل عليهم، تموتون معاً ويدفن الكنز تحت الأنقاض للأبد.",
              "is_ending": true,
              "choices": []
            },
            "n_09": {
              "text": "تموت متأثراً بجراحك داخل الكهف مظلماً بعد خسارة كنزك.",
