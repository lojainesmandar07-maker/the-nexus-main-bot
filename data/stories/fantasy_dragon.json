              "choices": []
            },
            "n_10": {
              "text": "تدمر المدينة وتبني كنزاً أعظم. تصبح أسطورة مرعبة يحذرون منها الأطفال.",
              "is_ending": true,
              "choices": []
            },
            "n_11": {
              "text": "تجد جبلاً بعيداً وتعيش بسلام دون كنز، متأملاً جمال الغروب لآلاف السنين.",
