          "theme": "الفانتازيا المظلمة",
          "world_type": "fantasy",
          "game_mode": "single",
          "nodes": {
            "start": {
              "text": "الخيمة الطبية ممتلئة. لديك جرعة سحرية واحدة. أمامك قائد الجيش ينزف، وطفل صغير يحتضر.",
              "choices": [
                {
                  "label": "انقذ القائد",
                  "emoji": "⚔️",
                  "next": "n_02",
                  "points_reward": 5
                },
                {
                  "label": "انقذ الطفل",
                  "emoji": "👶",
                  "next": "n_03",
                  "points_reward": 5
                },
                {
                  "label": "أخذ الطريق الجانبي",
                  "emoji": "💀",
                  "next": "dead",
                  "points_reward": 0
                }
              ]
            },
            "n_02": {
              "text": "القائد يعيش ويقود هجوماً مضاداً. الطفل يموت. القائد يطلب منك الانضمام للمقدمة كمعالج قتالي.",
              "choices": [
                {
                  "label": "اذهب للمقدمة",
                  "emoji": "⚔️",
                  "next": "n_04"
                },
                {
                  "label": "ابق في الخيمة",
                  "emoji": "⛺",
                  "next": "n_05"
                }
              ]
            },
            "n_03": {
              "text": "الطفل يعيش، لكن القائد يموت. الجيش ينهار بدون قائده. العدو يقتحم الخيمة الطبية.",
              "choices": [
                {
                  "label": "استسلم للعدو",
                  "emoji": "🏳️",
                  "next": "n_06"
                },
                {
                  "label": "قاوم بشراسة",
                  "emoji": "⚔️",
                  "next": "n_07"
                }
              ]
            },
            "dead": {
              "text": "أنت تسلك دربًا جانبيًا مشهورًا بأمانه، لكنك تجد نفسك في كمين سحري. يتسلل السحر حولك ويخمد قلبك. لقد انتهت قصتك.",
              "is_ending": true,
              "choices": []
            },
            "n_04": {
              "text": "في المقدمة، ترى القائد يتهور في هجومه. ساحر معادي يصوب نحوه.",
              "choices": [
                {
                  "label": "احمه بنفسك",
                  "emoji": "🛡️",
                  "next": "n_08"
                },
                {
                  "label": "عالج الجرحى",
                  "emoji": "🧪",
                  "next": "n_09"
                }
              ]
            },
            "n_05": {
              "text": "تستمر بعلاج الجرحى. يأتيك جندي خائن يعرض عليك ذهباً لتسميم القائد الجديد.",
              "choices": [
                {
                  "label": "اقبل العرض",
                  "emoji": "💰",
                  "next": "n_10"
                },
                {
                  "label": "افضحه للجنود",
                  "emoji": "🗣️",
                  "next": "n_11"
                }
              ]
            },
            "n_06": {
              "text": "العدو يأسرك، لكن مهاراتك تجعلهم يوظفونك لخدمتهم.",
              "choices": [
                {
                  "label": "اخدم بولاء",
                  "emoji": "❤️",
                  "next": "n_12"
                },
                {
                  "label": "خطط للهروب",
                  "emoji": "🏃",
                  "next": "n_13"
                }
              ]
            },
            "n_07": {
              "text": "تقاتل دفاعاً عن المرضى. تقتل واحداً لكنهم يتكاثرون عليك.",
              "choices": [
                {
                  "label": "استخدم السم",
                  "emoji": "🧪",
                  "next": "n_14"
                },
                {
                  "label": "اقبل الموت",
                  "emoji": "💀",
                  "next": "n_15"
                }
              ]
            },
            "n_08": {
              "text": "تتلقى الضربة بدلاً من القائد. تموت كبطل أسطوري ضحى بنفسه من أجل المملكة.",
              "is_ending": true,
              "choices": []
            },
            "n_09": {
              "text": "القائد يسقط لكنك تنقذ عشرات الجنود الذين يتراجعون وينظمون دفاعاً ناجحاً.",
              "is_ending": true,
              "choices": []
            },
            "n_10": {
              "text": "تسمم القائد وتهرب بالذهب لتعيش في عار وثراء لبقية حياتك.",
              "is_ending": true,
              "choices": []
            },
            "n_11": {
              "text": "تفضح الخائن. يعينك القائد كبيراً للأطباء والمستشارين مكافأة لك.",
              "is_ending": true,
              "choices": []
            },
            "n_12": {
              "text": "تعيش كمعالج مبجل في جيش الأعداء، لكن ذنب خيانتك يلاحقك طوال حياتك.",
              "is_ending": true,
              "choices": []
            },
            "n_13": {
              "text": "تفشل في الهروب وتعدم أمام الجميع كعبرة لمن يحاول التمرد.",
              "is_ending": true,
              "choices": []
            },
            "n_14": {
              "text": "ترمي زجاجات السم عليهم. يختنقون وتموت أنت معهم مضحياً بنفسك.",
              "is_ending": true,
              "choices": []
            },
            "n_15": {
              "text": "تموت كبطل يذكره كل مريض عالجته، وتصبح رمزاً للرحمة.",
              "is_ending": true,
              "choices": []
            }
          },
