          "theme": "الفانتازيا المظلمة",
          "world_type": "fantasy",
          "game_mode": "single",
          "nodes": {
            "start": {
              "text": "المطر ينهمر بشدة. أنت مجرد ساعي بريد، لكن الرسالة الملكية في حقيبتك ثقيلة. الجواد متعب، والظلام يخفي الطريق. فجأة، يظهر قطاع طرق أمامك.",
              "choices": [
                {
                  "label": "اهرب بالحصان",
                  "emoji": "🐎",
                  "next": "n_02",
                  "points_reward": 5
                },
                {
                  "label": "اختبئ في الغابة",
                  "emoji": "🌲",
                  "next": "n_03",
                  "points_reward": 0
                },
                {
                  "label": "أخذ الطريق الجانبي",
                  "emoji": "💀",
                  "next": "dead",
                  "points_reward": 0
                }
              ]
            },
            "n_02": {
              "text": "تركض بأقصى سرعة. سهم يمر بجانبك، لكنك تنجو. تصل إلى مفترق طرق. اليمين نحو الحصن، واليسار نحو قرية مهجورة.",
              "choices": [
                {
                  "label": "اذهب للحصن",
                  "emoji": "🏰",
                  "next": "n_04"
                },
                {
                  "label": "طريق القرية",
                  "emoji": "🏚️",
                  "next": "n_05"
                }
              ]
            },
            "n_03": {
              "text": "تترك الحصان وتختبئ. اللصوص يسرقون حصانك ويرحلون. أنت الآن راجل والرسالة لا زالت معك.",
              "choices": [
                {
                  "label": "أكمل مشياً",
                  "emoji": "🚶",
                  "next": "n_06"
                },
                {
                  "label": "افتح الرسالة",
                  "emoji": "✉️",
                  "next": "n_07",
                  "points_reward": 5
                }
              ]
            },
            "dead": {
              "text": "أنت تسلك دربًا جانبيًا مشهورًا بأمانه، لكنك تجد نفسك في كمين سحري. يتسلل السحر حولك ويخمد قلبك. لقد انتهت قصتك.",
              "is_ending": true,
              "choices": []
            },
            "n_04": {
              "text": "تصل الحصن. الحراس يشكون بك لأنك بلا ختم مرور. يطلبون تسليم الرسالة.",
              "choices": [
                {
                  "label": "سلم الرسالة",
                  "emoji": "🤝",
                  "next": "n_08"
                },
                {
                  "label": "ارفض التسليم",
                  "emoji": "🚫",
                  "next": "n_09",
                  "required_points": 5
                }
              ]
            },
            "n_05": {
              "text": "القرية ليست مهجورة. تجد جنوداً متمردين يخيمون هناك. يمسكون بك.",
              "choices": [
                {
                  "label": "ادع أنك فلاح",
                  "emoji": "🌾",
                  "next": "n_10"
                },
                {
                  "label": "اعترف بمهمتك",
                  "emoji": "🗣️",
                  "next": "n_11"
                }
              ]
            },
            "n_06": {
              "text": "تمشي لساعات. البرد قارس. تجد كهفاً صغيراً يمكنك الاحتماء به.",
              "choices": [
                {
                  "label": "ادخل الكهف",
                  "emoji": "🦇",
                  "next": "n_12"
                },
                {
                  "label": "تجاهل الكهف",
                  "emoji": "🚶",
                  "next": "n_13"
                }
              ]
            },
            "n_07": {
              "text": "تكسر الختم. تقرأ أن الملك يخطط لتسميم بئر المدينة المجاورة. هذه خيانة!",
              "choices": [
                {
                  "label": "حذر المدينة",
                  "emoji": "شهر",
                  "next": "n_14",
                  "points_reward": 5
                },
                {
                  "label": "تخلص من الرسالة",
                  "emoji": "🔥",
                  "next": "n_15"
                }
              ]
            },
            "n_08": {
              "text": "سلمت الرسالة. قائد الحصن يقرؤها ويأمر بإعدامك لضمان السرية.",
              "choices": [
                {
                  "label": "قاوم الحراس",
                  "emoji": "⚔️",
                  "next": "n_16"
                },
                {
                  "label": "توسل لحياتك",
                  "emoji": "🙏",
                  "next": "n_17"
                }
              ]
            },
            "n_09": {
              "text": "ترفض بقوة. شجاعتك تثير إعجابهم، يسمحون لك بمقابلة القائد شخصياً.",
              "choices": [
                {
                  "label": "تحدث للقائد",
                  "emoji": "🗣️",
                  "next": "n_18"
                },
                {
                  "label": "حاول الهرب",
                  "emoji": "🏃",
                  "next": "n_16"
                }
              ]
            },
            "n_10": {
              "text": "يصدقونك، لكنهم يصادرون حقيبتك. تفقد الرسالة وتنجو بحياتك. كيف تعوض فشلك؟",
              "choices": [
                {
                  "label": "عد للملك",
                  "emoji": "👑",
                  "next": "n_19"
                },
                {
                  "label": "عش كفلاح",
                  "emoji": "🌾",
                  "next": "n_20"
                }
              ]
            },
            "n_11": {
              "text": "تعترف. المتمردون يفتحون الرسالة ويقررون استخدامها لابتزاز الملك.",
              "choices": [
                {
                  "label": "انضم للمتمردين",
                  "emoji": "✊",
                  "next": "n_21"
                },
                {
                  "label": "ارفض الانضمام",
                  "emoji": "🚫",
                  "next": "n_17"
                }
              ]
            },
            "n_12": {
              "text": "تجد دباً نائماً. تتراجع بهدوء، لكن العاصفة بالخارج تشتد.",
              "choices": [
                {
                  "label": "خاطر بالعاصفة",
                  "emoji": "🌪️",
                  "next": "n_13"
                },
                {
                  "label": "اشعل ناراً",
                  "emoji": "🔥",
                  "next": "n_22"
                }
              ]
            },
            "n_13": {
              "text": "تمشي طويلاً في العاصفة. تلمح أضواء المدينة المجاورة من بعيد.",
              "choices": [
                {
                  "label": "اتجه للمدينة",
                  "emoji": "شهر",
                  "next": "n_14"
                },
                {
                  "label": "ابحث عن مأوى",
                  "emoji": "🏠",
                  "next": "n_20"
                }
              ]
            },
            "n_14": {
              "text": "تصل المدينة وتحذر العمدة. يجهزون دفاعاتهم ويتم إنقاذ الآلاف. أصبحت بطلاً مجهولاً.",
              "is_ending": true,
              "choices": []
            },
            "n_15": {
              "text": "تحرق الرسالة وتعيش حياتك كفلاح بسيط. المدينة المجاورة تدمر، والذنب يلاحقك طوال حياتك.",
              "is_ending": true,
              "choices": []
            },
            "n_16": {
              "text": "تفشل في مقاومتهم ويتم رميك في سجن القلعة حتى ينسى الجميع أمرك.",
              "is_ending": true,
              "choices": []
            },
            "n_17": {
              "text": "يضحكون عليك ويقتلونك بلا رحمة. السر مدفون معك.",
              "is_ending": true,
              "choices": []
            },
            "n_18": {
              "text": "القائد يتضح أنه من المتمردين. يأخذ الرسالة ويشكرك، يمنحك ذهباً لتبدأ حياة جديدة.",
              "is_ending": true,
              "choices": []
            },
            "n_19": {
              "text": "الملك يغضب من فشلك ويأمر بقطع رأسك لضمان عدم تسرب سره.",
              "is_ending": true,
              "choices": []
            },
            "n_20": {
              "text": "تعيش بقية أيامك مختبئاً عن عيون الملك والتمرد، سعيداً ببساطة الحياة وندمك المستمر.",
              "is_ending": true,
              "choices": []
            },
            "n_21": {
              "text": "تصبح جزءاً من التمرد. الرسالة كانت الشرارة لثورة ناجحة وأنت الآن قائد جيوشهم.",
              "is_ending": true,
              "choices": []
            },
            "n_22": {
              "text": "الدب يستيقظ ويهاجمك. نهايتك كانت في كهف مظلم بعيداً عن صراعات الملوك.",
              "is_ending": true,
              "choices": []
            }
